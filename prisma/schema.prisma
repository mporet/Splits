generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// NextAuth default Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  groupsAdministered ExpenseGroup[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Split App Models

model ExpenseGroup {
  id            String             @id @default(cuid())
  adminId       String
  name                   String
  passcode               String
  finalCurrency          String             @default("USD")
  defaultExpenseCurrency String             @default("USD")
  isClosed               Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  settlementData         String?            // JSON string containing ledger, exchange rates, total spend, etc.

  admin         User               @relation(fields: [adminId], references: [id], onDelete: Cascade)
  participants  GroupParticipant[]
  expenses      Expense[]
  debts         SettlementDebt[]
}

model GroupParticipant {
  id            String   @id @default(cuid())
  groupId       String
  name          String
  venmoUsername String?

  group     ExpenseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payments  ExpensePayer[]
  splits    ExpenseSplit[]

  @@unique([groupId, name])
}

model Expense {
  id          String   @id @default(cuid())
  groupId     String
  description String
  amount      Int      // Store in cents
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group       ExpenseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payers      ExpensePayer[]
  splits      ExpenseSplit[]
}

model ExpensePayer {
  id            String   @id @default(cuid())
  expenseId     String
  participantId String
  amountPaid    Int      // Cents

  expense       Expense          @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  participant   GroupParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

model ExpenseSplit {
  id            String   @id @default(cuid())
  expenseId     String
  participantId String
  amountSplit   Int      // Cents (exact amount of value owed by this person for this expense)
  splitType     String   // "EQUAL", "EXACT", "PERCENTAGE"
  percentage    Float?   // Only used if splitType is PERCENTAGE

  expense       Expense          @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  participant   GroupParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

model SettlementDebt {
  id        String   @id @default(cuid())
  groupId   String
  fromId    String
  toId      String
  amount    Int      // Cents
  isPaid    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group     ExpenseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}
